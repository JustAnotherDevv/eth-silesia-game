# Supabase (server — service role key, NEVER expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
PORT=3001

# Required for npm run seed — Supabase Personal Access Token
# Get from: https://supabase.com/dashboard/account/tokens  (Generate new token)
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx

# Optional fallback for npm run seed (direct postgres, may not work on new projects)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
